# ============================================================
# .env.example — Framework Multi-Site
# Copie para .env.local (desenvolvimento) e configure no Vercel.
# NÃO commitar .env.local com valores reais.
# ============================================================

# --- BASE URL ---
# Obrigatória em produção. Em development usa localhost:3000 automaticamente.
# Em preview usa VERCEL_URL automaticamente.
NEXT_PUBLIC_BASE_URL=https://seu-dominio.vercel.app

# --- GOOGLE ANALYTICS 4 ---
# IDs GA4 por site. Substitua pelos IDs reais do Google Analytics.
NEXT_PUBLIC_GA4_FINANCAS_BR=G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ENERGIA_SOLAR_BR=G-XXXXXXXXXX
NEXT_PUBLIC_GA4_AGROFLORESTA_BR=G-XXXXXXXXXX

# --- GOOGLE ADSENSE ---
# Publisher ID da conta AdSense. Formato: pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=pub-XXXXXXXXXXXXXXXX

# --- ADS TEST MODE ---
# true  = slots renderizam em modo de teste visual (sem AdSense real)
# false = slots carregam AdSense real (requer publisherId válido e conta aprovada)
NEXT_PUBLIC_ADS_TEST_MODE=true
